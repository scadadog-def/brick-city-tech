# Public base URL of the site (no trailing slash)
PUBLIC_BASE_URL=https://claw.hectorlopez.cloud

# Admin bootstrap allowlist (comma-separated)
ADMIN_EMAIL_ALLOWLIST=Hector.Lopez@scadadog.com

# REQUIRED: set to a long random secret in production
SESSION_SECRET=change-me

# Google OAuth (create in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional SMTP for email verification
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
