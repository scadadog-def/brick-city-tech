# Build frontend
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

# Serve with nginx
FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
# Put under /brick-city-tech/ because Vite base is /brick-city-tech/
COPY --from=build /app/dist /usr/share/nginx/html/brick-city-tech
